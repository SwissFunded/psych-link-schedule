# Vitabyte ePAD API Configuration
# Copy this file to .env and fill in your actual credentials

# Basic Authentication credentials for Vitabyte ePAD API
VITE_EPAT_USERNAME=your_vitabyte_username
VITE_EPAT_PASSWORD=your_vitabyte_password

# Note: These credentials will be used for Basic Authentication
# The API client will automatically encode them as: Basic base64(username:password)

# For Vercel deployment, add these variables in your Vercel project settings:
# Dashboard > Project > Settings > Environment Variables
VITE_EPAT_API_URL=https://psych.vitabyte.ch
